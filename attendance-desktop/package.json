{
  "name": "attendance-desktop",
  "productName": "AttendNest",
  "version": "1.0.0",
  "description": "Secure Employee Attendance Management Desktop App",
  "main": "src/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "keywords": [
    "attendance",
    "electron",
    "desktop",
    "trusted-device"
  ],
  "author": "AttendNest",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "electron": "^28.2.0"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "AttendNest",
        "executableName": "AttendNest",
        "asar": true
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "platforms": [
            "win32"
          ],
          "config": {
            "name": "AttendNest",
            "setupExe": "AttendNestSetup.exe",
            "setupIcon": ""
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "win32"
          ]
        }
      ]
    }
  }
}